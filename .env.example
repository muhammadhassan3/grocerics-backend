# Copy this file to .env and fill in real values for your machine.
# .env is git-ignored — never commit actual secrets.

# --- App ---
ENV=development
PORT=8080
# Comma-separated list of allowed CORS origins
FRONTEND_ORIGINS=http://localhost:5500,http://localhost:3000

# --- Database (Postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=grocerics
DB_SSLMODE=disable

# --- JWT ---
# Generate a strong secret, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=change-me

# --- Seed (dev/staging only — skipped when ENV=production) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=adminpassword

# --- QuickCommerce API (price/availability/ETA source) ---
# Leave QC_API_KEY blank to use the built-in mock client (no real API calls).
QC_API_KEY=
QC_BASE_URL=

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket-name
