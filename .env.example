# Copy to .env next to docker-compose.yml and fill in real values. NEVER commit .env.
#   cp .env.example .env && nano .env && docker compose -p groceric up -d
# Docker auto-loads .env — no --env-file flag needed. Anything omitted falls back
# to the safe local-dev default in docker-compose.yml.

# ENV: any value other than "production" runs the DB seed (admin user + platforms
# + city + demo catalog). "production" skips all seeding.
ENV=development

# Host ports on 127.0.0.1 (nginx proxies to these). Override when the defaults
# collide with other stacks on a shared box.
API_HOST_PORT=8090
DB_HOST_PORT=5433

DB_USER=grocerics
DB_NAME=grocerics
# openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_strong_db_password

# openssl rand -base64 48  — forge-able admin tokens if left default. Set it.
JWT_SECRET_KEY=CHANGE_ME_long_random_secret

SEED_ADMIN_EMAIL=admin@fortheye.co
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_password

# CORS: the frontend origin(s), comma-separated, https, no trailing slash.
FRONTEND_ORIGINS=https://groceric.fortheye.net

# QuickCommerce (blank => mock client).
QC_API_KEY=cf0fed25-4bac-44b4-a5ad-ec2b3f9aee79
QC_BASE_URL=

# AWS S3 (dummy is fine to boot; real creds only needed for image uploads).
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_REGION=us-east-1
AWS_BUCKET_NAME=grocerics-prod
